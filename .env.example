# App
APP_NAME=Sender-Report
# Internal listen addresses INSIDE the container — do NOT change these when using Docker.
# Docker maps the host ports (HTTP_PORT / SMTP_PORT below) to these internal addresses.
# Changing these here without adjusting docker-compose.yml will break the port mapping.
HTTP_LISTEN_ADDR=:8080
SMTP_LISTEN_ADDR=:2525
# Optional overrides. Leave empty to derive these from the incoming request host.
PUBLIC_BASE_URL=
SMTP_DOMAIN=

# Optional direct TLS for the built-in web server.
# If ENABLE_TLS=true, both TLS_CERT_FILE and TLS_KEY_FILE must point to mounted files.
# FORCE_HTTPS redirects plain HTTP requests to HTTPS when the app receives HTTP traffic
# directly or via trusted reverse-proxy forwarded headers.
ENABLE_TLS=false
TLS_CERT_FILE=
TLS_KEY_FILE=
FORCE_HTTPS=false

# Container image from CI registry (adjust owner/repo)
SENDER_REPORT_IMAGE=ghcr.io/brightcolor/sender-report:latest

# Runtime paths
DATA_DIR=/data
DB_PATH=/data/mailprobe.db

# Lifetime & cleanup
MAILBOX_TTL=24h
DATA_RETENTION_TTL=168h
CLEANUP_INTERVAL=30m

# Abuse protection
MAX_MESSAGE_BYTES=2097152
MAX_ACTIVE_MAILBOXES_PER_IP=20
MAX_ACTIVE_MAILBOXES_GLOBAL=2000
WEB_RATE_LIMIT_PER_MIN=60
WEB_BURST_PER_10_SEC=20
SMTP_RATE_LIMIT_PER_HOUR=200
SMTP_BURST_PER_MIN=40
# Comma-separated reverse proxy CIDRs whose X-Forwarded-For header is trusted.
TRUSTED_PROXY_CIDRS=

# Optional checks
ENABLE_RBL_CHECKS=false
RBL_PROVIDERS=zen.spamhaus.org,bl.spamcop.net,b.barracudacentral.org,psbl.surriel.com,dnsbl.dronebl.org,bl.blocklist.de
ENABLE_SPAMASSASSIN=false
SPAMASSASSIN_HOSTPORT=spamd:783
ENABLE_RSPAMD=false
RSPAMD_URL=http://rspamd:11334/checkv2
RSPAMD_PASSWORD=
ENABLE_REDIS=false
REDIS_ADDR=redis:6379

# Optional alerting webhook (JSON POST on processing failures)
ALERT_WEBHOOK_URL=

# Privacy page operator contact (shown in the "Wer ist verantwortlich?" section)
# Leave empty to show the generic placeholder text.
PRIVACY_OPERATOR_NAME=
PRIVACY_OPERATOR_ADDRESS=
PRIVACY_OPERATOR_EMAIL=
# Set to true once you have filled in your operator details to hide the setup note.
PRIVACY_HIDE_TEMPLATE_NOTE=false

# Runtime ports mapped by docker-compose
# HTTP_PORT: host port for the web UI (container always listens on :8080 internally)
HTTP_PORT=9090
# SMTP_PORT: host port for inbound SMTP. External mail servers (Gmail, etc.) always
# connect on port 25. Set SMTP_PORT=25 in production and make sure no other MTA
# (postfix, exim, sendmail) is running. Port 2525 is only for local testing.
SMTP_PORT=25
HEALTHCHECK_URL=http://127.0.0.1:9090/healthz

# Env migration — path inside the container to the mounted .env file.
# When set, the binary appends any missing variables on every startup so your
# .env stays in sync after a Watchtower pull without manual intervention.
# The default docker-compose.yml mounts ./.env here automatically.
ENV_FILE=/config/.env
